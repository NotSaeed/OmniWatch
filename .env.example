# OmniWatch Environment Variables
# Copy this file to .env and fill in your values

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Threat Intelligence APIs (Phase 6) ───────────────────────────────────────
# AbuseIPDB: https://www.abuseipdb.com/account/api  (free tier: 1000 checks/day)
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
# VirusTotal: https://www.virustotal.com/gui/my-apikey  (free tier: 4 req/min)
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# ── Notification Webhooks (Phase 6) ──────────────────────────────────────────
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
# Slack (optional): https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── Application Settings ──────────────────────────────────────────────────────
# How many log lines to feed Claude per triage chunk
TRIAGE_CHUNK_SIZE=50

# Minimum confidence score to trigger a Micro-SOAR playbook (0.0–1.0)
SOAR_CONFIDENCE_THRESHOLD=0.75

# Set to "true" to run SOAR playbooks for real (NOT recommended — demo mode is safer)
SOAR_LIVE_MODE=false

# Auto-scan interval in seconds (0 = disabled, only manual trigger)
AUTO_SCAN_INTERVAL=60

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./omniwatch.db

# ── BOTSv3 Dataset ────────────────────────────────────────────────────────────
# Path to BOTSv3 JSON export file (leave blank to use simulated logs)
BOTSV3_FILE_PATH=./data/botsv3/botsv3_dataset.json

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
